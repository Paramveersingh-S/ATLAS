# ATLAS Configuration — copy to .env and fill in

# Backend
ATLAS_HOST=0.0.0.0
ATLAS_PORT=8000
SECRET_KEY=generate_this_secret_key_hex_32
DEBUG=false

# Paths
DATABASE_PATH=./data/atlas.db
INDEX_PATH=./data/index/
DOCUMENT_STORE_PATH=./data/documents/
CACHE_PATH=./data/cache/

# Models
LLM_MODEL_PATH=./models/Llama-3.2-3B-Instruct.Q8_0.gguf
EMBEDDING_MODEL_PATH=./models/nomic-embed-text-v1.5
EMBEDDING_DIM=768
RERANKER_MODEL_PATH=./models/cross-encoder-ms-marco-MiniLM-L-6-v2

# vLLM Settings (if using GPU)
VLLM_PORT=8001
VLLM_GPU_MEMORY_UTIL=0.85
USE_VLLM=true    # false = use llama-cpp-python

# TurboQuant Settings
TQ_BITS=3                     # 3 = near-lossless (recommended), 4 = lossless+faster
TQ_BITS_K=3                   # bit budget for Key vectors
TQ_BITS_V=3                   # bit budget for Value vectors
ENABLE_TQ_KV_CACHE=true
ENABLE_TQ_VECTOR_SEARCH=true
TQ_PRECOMPUTE_SEED=42         # random seed for rotation matrix (DO NOT CHANGE after indexing)

# Chunking
CHUNK_MIN_TOKENS=200
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=50

# Retrieval
RETRIEVAL_TOP_K=20            # chunks retrieved per query
RETRIEVAL_CANDIDATES=200      # candidates for QJL fast phase before rerank
RETRIEVAL_MIN_SCORE=0.5
HYBRID_BM25_WEIGHT=0.3        # weight for BM25 in hybrid search (0 = pure semantic)
ENABLE_RERANKER=true

# Security
ENCRYPT_DOCUMENT_STORE=false
DOCUMENT_STORE_KEY=           # set if ENCRYPT_DOCUMENT_STORE=true (AES-256 key hex)
JWT_EXPIRE_HOURS=168          # 1 week
